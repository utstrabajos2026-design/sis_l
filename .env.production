# ConfiguraciĂ³n para Hugging Face Spaces
# Use este archivo cuando despliegue en HF Spaces

# Puerto (HF Spaces requiere 7860)
PORT=7860

# Base de datos - usar servicio externo (ej: Railway, Render, etc)
DB_HOST=${DB_HOST:-localhost}
DB_PORT=${DB_PORT:-3306}
DB_USER=${DB_USER:-root}
DB_PASSWORD=${DB_PASSWORD:-}
DB_NAME=${DB_NAME:-sisl}

# Ollama / LLM - opcional, puede ser externo
OLLAMA_HOST=${OLLAMA_HOST:-}
OLLAMA_MODEL=${OLLAMA_MODEL:-neural-chat:latest}

# Seguridad
NODE_ENV=production
JWT_SECRET=${JWT_SECRET:-tu-llave-secreta-aqui}

# Email
SMTP_HOST=${SMTP_HOST:-}
SMTP_PORT=${SMTP_PORT:-587}
SMTP_USER=${SMTP_USER:-}
SMTP_PASS=${SMTP_PASS:-}
EMAIL_FROM=${EMAIL_FROM:-noreply@example.com}

# Frontend
VITE_API_URL=https://tu-space-url.hf.space/api
